{
  "_comment": "Sorcerer configuration. Copy to <project>/.sorcerer/config.json (or the project bootstrap writes this automatically on first /sorcerer invocation). Fields documented in docs/setup.md.",

  "repos": [
    "github.com/b/sorcerer"
  ],

  "explorable_repos": [
    "github.com/b/sorcerer"
  ],

  "linear": {
    "default_team_key": "ENG",
    "wizard_label": "wizard"
  },

  "models": {
    "coordinator":        "claude-opus-4-7",
    "architect":          "claude-opus-4-7",
    "designer":           "claude-opus-4-7",
    "executor":           "claude-opus-4-7",
    "reviewer":           "claude-opus-4-7",
    "reviewer_architect": "claude-opus-4-7",
    "reviewer_design":    "claude-opus-4-7"
  },

  "effort": {
    "coordinator":        "xhigh",
    "architect":          "xhigh",
    "designer":           "xhigh",
    "executor":           "high",
    "reviewer":           "xhigh",
    "reviewer_architect": "max",
    "reviewer_design":    "max"
  },

  "architect": {
    "auto_threshold": {
      "min_repos": 3,
      "min_issues_estimate": 12
    }
  },

  "limits": {
    "max_concurrent_wizards": 3,
    "max_refer_back_cycles": 5,
    "max_wizard_age_seconds": {
      "architect":          1800,
      "architect-review":    900,
      "design":             2700,
      "design-review":      1200,
      "implement":         10800,
      "feedback":           3600,
      "rebase":             1800
    }
  },

  "merge": {
    "strategy": "squash",
    "delete_branch": true
  },

  "_providers_comment": "Primary → fallback auth slots. scripts/apply-provider-env.sh picks the first entry whose providers_state[name].throttled_until is null or in the past and exports its env map before each claude -p call. ${VAR} expands from the shell env (so put the secrets in ~/.shell_env, not here). Omit the whole key or use [] to run against ambient auth only.",
  "providers": [
    {
      "name": "max-primary",
      "env": {
        "CLAUDE_CODE_OAUTH_TOKEN": "${CLAUDE_CODE_OAUTH_TOKEN_A}"
      }
    },
    {
      "name": "max-secondary",
      "env": {
        "CLAUDE_CODE_OAUTH_TOKEN": "${CLAUDE_CODE_OAUTH_TOKEN_B}"
      }
    }
  ]
}
